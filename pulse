#!/usr/bin/env bash
# Claude Pulse — live session monitor
# Usage: pulse [--port PORT] [--host HOST] [--no-open] [--tunnel [HOST]]

PULSE_DIR="$(cd "$(dirname "$(readlink -f "$0" 2>/dev/null || realpath "$0" 2>/dev/null || echo "$0")")" && pwd)"
PORT=8420
HOST="127.0.0.1"
OPEN=true
TUNNEL=false
TUNNEL_VIA=""
DEFAULT_TUNNEL_HOST="my-remote-host"       # Default remote host for tunneling (has cloudflared installed)

while [[ $# -gt 0 ]]; do
  case $1 in
    --port) PORT="$2"; shift 2 ;;
    --host) HOST="$2"; shift 2 ;;
    --no-open) OPEN=false; shift ;;
    --tunnel)
      TUNNEL=true
      # Optional: --tunnel <ssh-host> to route tunnel via a remote machine
      if [[ $# -ge 2 && ! "$2" =~ ^-- ]]; then
        TUNNEL_VIA="$2"; shift
      fi
      shift
      ;;
    -h|--help)
      echo "Claude Pulse — live session monitor"
      echo ""
      echo "Usage: pulse [OPTIONS]"
      echo ""
      echo "Options:"
      echo "  --port PORT        Port to listen on (default: 8420)"
      echo "  --host HOST        Host to bind to (default: 127.0.0.1)"
      echo "  --no-open          Don't auto-open browser"
      echo "  --tunnel           Expose via Cloudflare Tunnel (through $DEFAULT_TUNNEL_HOST)"
      echo "  --tunnel <host>    Expose via Cloudflare Tunnel through a specific SSH host"
      echo "  -h, --help         Show this help"
      exit 0
      ;;
    *) echo "Unknown option: $1"; exit 1 ;;
  esac
done

# Check dependencies
if ! python3 -c "import fastapi, uvicorn, watchdog" 2>/dev/null; then
  echo "Installing dependencies..."
  pip3 install -q -r "$PULSE_DIR/requirements.txt"
fi

# Kill any existing pulse on the same port
lsof -ti tcp:"$PORT" 2>/dev/null | xargs kill 2>/dev/null
sleep 0.5

ARGS="--host $HOST --port $PORT"
if $OPEN; then
  ARGS="$ARGS --open"
fi

cd "$PULSE_DIR"

if $TUNNEL; then
  # Use the specified host, or default to my-remote-host
  [[ -z "$TUNNEL_VIA" ]] && TUNNEL_VIA="$DEFAULT_TUNNEL_HOST"

  # Start the server in background
  python3 server.py $ARGS &
  SERVER_PID=$!
  sleep 2

  echo ""
  echo "Setting up Cloudflare tunnel via $TUNNEL_VIA..."
  echo "  1) SSH reverse tunnel: localhost:$PORT → $TUNNEL_VIA:$PORT"
  echo "  2) cloudflared on $TUNNEL_VIA → public *.trycloudflare.com URL"
  echo ""

  # Ensure cloudflared exists on the remote; kill any stale tunnel/port processes
  ssh -o ConnectTimeout=5 -o BatchMode=yes "$TUNNEL_VIA" \
    'test -x ~/cloudflared || (curl -sL https://github.com/cloudflare/cloudflared/releases/latest/download/cloudflared-linux-amd64 -o ~/cloudflared && chmod +x ~/cloudflared); pkill -f cloudflared 2>/dev/null; fuser -k '"$PORT"'/tcp 2>/dev/null; true' 2>/dev/null
  sleep 1

  HEALTH_PID=""
  cleanup() {
    kill $HEALTH_PID 2>/dev/null
    kill $SERVER_PID 2>/dev/null
    kill $TUNNEL_PID 2>/dev/null
    kill $CF_PID 2>/dev/null
    ssh -o ConnectTimeout=5 -o BatchMode=yes "$TUNNEL_VIA" 'pkill -f cloudflared 2>/dev/null; true' 2>/dev/null
    exit
  }
  trap cleanup INT TERM EXIT

  # Step 1: SSH reverse tunnel (keeps local:PORT accessible on remote:PORT)
  ssh -o ServerAliveInterval=30 -o ServerAliveCountMax=3 \
    -N -R "0.0.0.0:$PORT:localhost:$PORT" "$TUNNEL_VIA" &
  TUNNEL_PID=$!
  sleep 2

  if ! kill -0 $TUNNEL_PID 2>/dev/null; then
    echo "ERROR: SSH reverse tunnel to $TUNNEL_VIA failed"
    kill $SERVER_PID 2>/dev/null
    exit 1
  fi

  # Step 2: Run cloudflared on the remote machine
  # Check if a named tunnel is configured (e.g., for a custom domain)
  HAS_NAMED_TUNNEL=$(ssh -o ConnectTimeout=5 -o BatchMode=yes "$TUNNEL_VIA" \
    'grep -q "^tunnel:" ~/.cloudflared/config.yml 2>/dev/null && echo yes || echo no' 2>/dev/null)

  if [[ "$HAS_NAMED_TUNNEL" == "yes" ]]; then
    TUNNEL_HOSTNAME=$(ssh -o ConnectTimeout=5 -o BatchMode=yes "$TUNNEL_VIA" \
      'grep "hostname:" ~/.cloudflared/config.yml 2>/dev/null | head -1 | awk "{print \$NF}"' 2>/dev/null)
    echo "Starting named cloudflared tunnel on $TUNNEL_VIA..."
    echo "  Public URL: https://$TUNNEL_HOSTNAME"
    echo ""
    ssh -o ConnectTimeout=10 -o ServerAliveInterval=30 -o ServerAliveCountMax=3 \
      "$TUNNEL_VIA" "\$HOME/cloudflared tunnel --config ~/.cloudflared/config.yml run 2>&1" &
    CF_PID=$!
  else
    echo "Starting cloudflared quick tunnel on $TUNNEL_VIA..."
    echo "(Your public URL will appear below)"
    echo ""
    ssh -o ConnectTimeout=10 -o ServerAliveInterval=30 -o ServerAliveCountMax=3 \
      "$TUNNEL_VIA" "\$HOME/cloudflared tunnel --url http://localhost:$PORT 2>&1" &
    CF_PID=$!
  fi

  # Background health monitor: restart server if it dies
  (while true; do
    sleep 10
    if ! kill -0 $SERVER_PID 2>/dev/null; then
      echo "Server died. Restarting..."
      python3 server.py $ARGS &
      SERVER_PID=$!
    fi
  done) &
  HEALTH_PID=$!

  # Wait for it to start
  sleep 6
  if kill -0 $CF_PID 2>/dev/null; then
    wait $CF_PID
  else
    echo "ERROR: cloudflared failed to start on $TUNNEL_VIA"
    kill $SERVER_PID 2>/dev/null
    kill $TUNNEL_PID 2>/dev/null
    exit 1
  fi
else
  MAX_RESTARTS=100
  RESTART_DELAY=3
  restart_count=0
  while true; do
    python3 server.py $ARGS
    exit_code=$?
    if [ $exit_code -eq 0 ]; then break; fi
    restart_count=$((restart_count + 1))
    if [ $restart_count -ge $MAX_RESTARTS ]; then
      echo "Pulse crashed $MAX_RESTARTS times. Giving up."
      exit 1
    fi
    echo "Pulse exited with code $exit_code. Restarting in ${RESTART_DELAY}s... ($restart_count/$MAX_RESTARTS)"
    sleep $RESTART_DELAY
  done
fi
